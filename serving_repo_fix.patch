+def sanitize_for_onnx_inplace(obj) -> None:
+    """Best-effort in-place sanitizer for exporting the recovered sklearn text pipeline.
+
+    The training artifact uses text vectorizers that are slightly stricter than what
+    skl2onnx supports. We patch only the export-time object and leave the source artifact intact.
+    """
+    if isinstance(obj, (CountVectorizer, TfidfVectorizer)):
+        obj.strip_accents = None
+        return
+
+    if isinstance(obj, Pipeline):
+        for _, step in obj.steps:
+            sanitize_for_onnx_inplace(step)
+        return
+
+    if isinstance(obj, ColumnTransformer):
+        for _, trans, _ in obj.transformers:
+            if trans not in ("drop", "passthrough"):
+                sanitize_for_onnx_inplace(trans)
+
+        if hasattr(obj, "transformers_"):
+            for _, trans, _ in obj.transformers_:
+                if trans not in ("drop", "passthrough"):
+                    sanitize_for_onnx_inplace(trans)
+        return
+
+    if isinstance(obj, FeatureUnion):
+        for _, trans in obj.transformer_list:
+            sanitize_for_onnx_inplace(trans)
+
+        if hasattr(obj, "transformer_list_"):
+            for _, trans in obj.transformer_list_:
+                sanitize_for_onnx_inplace(trans)
+        return
+
+
