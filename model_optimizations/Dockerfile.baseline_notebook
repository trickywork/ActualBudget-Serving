FROM python:3.10-slim

WORKDIR /workspace

COPY model_optimizations/baseline_service/requirements.txt /tmp/baseline-requirements.txt
RUN pip install --no-cache-dir -r /tmp/baseline-requirements.txt && \
    pip install --no-cache-dir jupyterlab==4.2.5 nbconvert nbformat ipykernel pandas matplotlib psutil

COPY model_optimizations /workspace/model_optimizations

CMD ["python", "/workspace/model_optimizations/scripts/execute_notebook.py", "--input", "/workspace/model_optimizations/notebooks/baseline_http_eval.ipynb", "--output", "/workspace/model_optimizations/results/baseline_http_eval.executed.ipynb"]
