FROM python:3.10-slim

WORKDIR /workspace

COPY model_optimizations/requirements-modelopt.txt /tmp/modelopt-requirements.txt
RUN pip install --no-cache-dir -r /tmp/modelopt-requirements.txt && \
    pip install --no-cache-dir nbconvert nbformat ipykernel

COPY model_optimizations /workspace/model_optimizations

CMD ["python", "/workspace/model_optimizations/scripts/execute_notebook.py", "--input", "/workspace/model_optimizations/notebooks/model_optimization_cpu.ipynb", "--output", "/workspace/model_optimizations/results/model_optimization_cpu.executed.ipynb"]
